# All server-side env lives in Netlify (Site settings → Environment variables).
# Nothing here is needed for `npm run dev` — the Stripe functions and Netlify
# Forms only work on Netlify deploys anyway.

# Stripe secret key. Use the TEST key in the "Deploy previews" scope and the
# LIVE key in the "Production" scope — that's the test/live switch.
STRIPE_SECRET_KEY=

# Cloudinary API credentials — enable signed, expiring paid-download links in
# verify-session. Without them delivery falls back to permanent public URLs.
# NEVER reuse the pair that leaked into git history (rotated July 2026).
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional — defaults to the site cloud (duwhxzb0q) if unset.
CLOUDINARY_CLOUD_NAME=

# URL is provided automatically by Netlify; no need to set it.
